rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── helpers ────────────────────────────────────────────────
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function ownsList(listId) {
      return signedIn()
        && exists(/databases/$(database)/documents/lists/$(listId))
        && get(/databases/$(database)/documents/lists/$(listId)).data.created_by == request.auth.uid;
    }

    // ─── /lists ─────────────────────────────────────────────────
    match /lists/{listId} {
      allow create: if isOwner(request.resource.data.created_by)
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 80
        && request.resource.data.is_archived is bool;

      allow read, delete: if signedIn()
        && resource.data.created_by == request.auth.uid;

      allow update: if signedIn()
        && resource.data.created_by == request.auth.uid
        && request.resource.data.created_by == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1;
    }

    // ─── /items ─────────────────────────────────────────────────
    match /items/{itemId} {
      allow create: if isOwner(request.resource.data.created_by)
        && ownsList(request.resource.data.list_id)
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 120
        && request.resource.data.is_checked is bool;

      allow read, delete: if ownsList(resource.data.list_id);

      allow update: if ownsList(resource.data.list_id)
        && ownsList(request.resource.data.list_id)
        && request.resource.data.created_by == resource.data.created_by
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.is_checked is bool;
    }

    // ─── /purchases ─────────────────────────────────────────────
    match /purchases/{purchaseId} {
      allow create: if isOwner(request.resource.data.created_by)
        && ownsList(request.resource.data.list_id);

      allow read, delete: if ownsList(resource.data.list_id);

      allow update: if ownsList(resource.data.list_id)
        && ownsList(request.resource.data.list_id)
        && request.resource.data.created_by == resource.data.created_by;
    }

    // ─── /budgets ───────────────────────────────────────────────
    match /budgets/{budgetId} {
      allow create: if isOwner(request.resource.data.created_by);

      allow read, delete: if signedIn()
        && resource.data.created_by == request.auth.uid;

      allow update: if signedIn()
        && resource.data.created_by == request.auth.uid
        && request.resource.data.created_by == request.auth.uid;
    }

    // ─── bloqueio total de tudo que não foi explicitado ─────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
